    "emoji-picker-react": "^4.12.0",
    "framer-motion": "^12.23.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sharp": "^0.33.5",
    "sqlite3": "^6.0.1"
  },
  "overrides": {
    "@electron/rebuild": "^4.0.4",
    "@inquirer/prompts": "^7.10.1",
    "uuid": "^11.1.1"
