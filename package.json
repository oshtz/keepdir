{
  "name": "keepdir",
  "version": "0.1.1",
  "description": "keepdir Desktop Application",
  "scripts": {
    "start": "npm run dev",
    "dev": "tauri dev",
    "dev:web": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "tauri": "tauri",
    "tauri:build": "tauri build",
    "package": "npm run tauri:build",
    "make": "npm run tauri:build",
    "dist": "npm run tauri:build",
    "dist:win": "tauri build --no-bundle && powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows-portable.ps1",
    "dist:mac": "tauri build --bundles dmg",
    "typecheck": "tsc --noEmit --pretty false",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint/",
    "format": "prettier --write package.json package-lock.json tsconfig.json jest.config.js vite.config.ts eslint.config.mjs README.md .github/workflows/build.yml",
    "format:check": "prettier --check package.json package-lock.json tsconfig.json jest.config.js vite.config.ts eslint.config.mjs README.md .github/workflows/build.yml",
    "check": "npm run format:check && npm run typecheck && npm run lint && npm run test:ci && npm run build",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",
    "test:ci": "jest --ci --watchAll=false --runInBand",
    "test:e2e": "tauri build --debug",
    "test:runtime": "powershell -ExecutionPolicy Bypass -File scripts/runtime-smoke.ps1",
    "verify": "npm run check && npm run audit:prod && npm run rust:test && npm run rust:clippy && npm run test:e2e && npm run test:runtime"
  },
  "author": "oshtz",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "babel-jest": "^30.1.2",
    "eslint": "^10.4.1",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.1.3",
    "jest-environment-jsdom": "^30.1.2",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.1",
    "ts-jest": "^29.4.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^7.3.5"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.4.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "clsx": "^2.1.1",
    "phosphor-react": "^1.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.6.0"
  }
}
